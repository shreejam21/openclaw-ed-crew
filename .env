# CrewAI Enterprise deployment env file.
# Baked into the deployment at `crewai deploy create` time.
# To change: delete and recreate the deployment.
#
# LLM routes to OpenClaw on-prem via a Cloudflare tunnel — keeps Copilot license usage
# while letting CrewAI's container reach the endpoint.
OPENAI_API_KEY=9e34a81afd4971ed94a5e3acf0c4208b5441a1f9b0f98495
OPENAI_API_BASE=https://connecting-gate-chris-servers.trycloudflare.com/v1
OPENAI_BASE_URL=https://connecting-gate-chris-servers.trycloudflare.com/v1
MODEL=hosted_vllm/openclaw
OPENCLAW_LLM_BASE=https://connecting-gate-chris-servers.trycloudflare.com/v1
