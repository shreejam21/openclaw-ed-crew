# CrewAI Enterprise deployment env file.
# OPENAI_API_KEY is required by the validator; the actual value is set as a
# deployment secret in the CrewAI dashboard. Locally we override it via shell
# env to point at OpenClaw's /v1/chat/completions endpoint.
OPENAI_API_KEY=set-in-crewai-dashboard
OPENAI_API_BASE=https://your-openclaw-public-url.example/v1
MODEL=hosted_vllm/openclaw
